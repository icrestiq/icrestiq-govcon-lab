# Copy this file to .env.local and fill in your values
# Get these from your Supabase project dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe — get from dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key-here

# These go in Vercel environment variables ONLY (never in .env.local for production)
# STRIPE_SECRET_KEY=sk_live_your-secret-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ConvertKit (now called Kit) — kit.com
# Free up to 10,000 subscribers
CONVERTKIT_API_KEY=your-convertkit-api-key
CONVERTKIT_FORM_ID=your-form-id
